{
  "templateId": "questionnaire-report-lean",
  "organizationId": "research.data.no",
  "version": "2.17.0",
  "name": "Questionnaire Report - lean",
  "description": "Exported questions and answers from a questionnaire",
  "license": "Apache-2.0",
  "metamodelVersion": "18.0",
  "allowedPackages": [
    {
      "orgId": null,
      "kmId": null,
      "minVersion": null,
      "maxVersion": null
    }
  ],
  "formats": [
    {
      "uuid": "a9293d08-59a4-4e6b-ae62-7a6a570b031c",
      "name": "HTML Document",
      "icon": "far fa-file-code",
      "steps": [
        {
          "name": "jinja",
          "options": {
            "content-type": "text/html",
            "extension": "html",
            "template": "src/default.html.j2"
          }
        }
      ]
    },
    {
      "uuid": "d3e98eb6-344d-481f-8e37-6a67b6cd1ad2",
      "name": "JSON Data",
      "icon": "far fa-file",
      "steps": [
        {
          "name": "json",
          "options": {}
        }
      ]
    },
    {
      "uuid": "dbc94579-40d7-42c3-975c-71e30d07778b",
      "name": "LaTeX Document",
      "icon": "far fa-file-alt",
      "steps": [
        {
          "name": "jinja",
          "options": {
            "content-type": "text/x-tex",
            "extension": "tex",
            "template": "src/default.tex.j2"
          }
        }
      ]
    },
    {
      "uuid": "f0533e48-f4c5-4af2-b2c1-5a47d4a247c0",
      "name": "Markdown Document",
      "icon": "far fa-file-alt",
      "steps": [
        {
          "name": "jinja",
          "options": {
            "content-type": "text/html",
            "extension": "md",
            "template": "src/default.md.j2"
          }
        }
      ]
    },
    {
      "uuid": "f4bd941a-dfbe-4226-a1fc-200fb5269311",
      "name": "MS Word Document",
      "icon": "far fa-file-word",
      "steps": [
        {
          "name": "jinja",
          "options": {
            "content-type": "text/html",
            "extension": "html",
            "template": "src/for-word.html.j2"
          }
        },
        {
          "name": "pandoc",
          "options": {
            "args": "--filter=pandoc-docx-pagebreakpy --reference-doc=src/reference.docx",
            "from": "html",
            "to": "docx"
          }
        }
      ]
    },
    {
      "uuid": "68c26e34-5e77-4e15-9bf7-06ff92582257",
      "name": "PDF Document",
      "icon": "far fa-file-pdf",
      "steps": [
        {
          "name": "jinja",
          "options": {
            "content-type": "text/html",
            "extension": "html",
            "template": "src/default.html.j2"
          }
        },
        {
          "name": "weasyprint",
          "options": {}
        }
      ]
    }
  ],
  "_tdk": {
    "version": "4.28.0",
    "readmeFile": "README.md",
    "files": [
	  "src/default.css",
	  "src/default.md.j2",
	  "src/for-word.html.j2",
	  "src/default.html.j2",  
	  "src/default.tex.j2",
	  "src/reference.docx",
      "!.git/",
      "!.env"
    ]
  }
}